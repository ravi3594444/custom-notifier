<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ================================================================== -->
    <!-- Call Video Wallpaper feature permissions                            -->
    <!-- ================================================================== -->

    <!-- Needed to receive ACTION_PHONE_STATE_CHANGED broadcasts so we know
         when a call is ringing. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Needed on API 28+ to read phone state and (defensively) the
         incoming phone number. We don't actually read the number, but some
         OEM ROMs refuse to deliver the broadcast without this permission. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Needed to read the contact list and display caller names -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Needed on API 26+ to programmatically answer calls via
         TelecomManager.acceptRingingCall(). -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Lets the CallVideoActivity turn the screen on and show over the
         lockscreen when a call arrives. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- On Android 14+ (API 34+), apps need this permission to launch a
         full-screen intent from a broadcast receiver. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Required for foreground service that monitors calls -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <!-- Required on Android 13+ for notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ============================================================ -->
        <!-- Call Video Wallpaper feature components                       -->
        <!-- ============================================================ -->

        <!-- Full-screen activity that plays the user's chosen video when a
             call arrives. Excludes from recents so the video wallpaper
             doesn't linger in the recent-apps carousel. -->
        <activity
            android:name=".CallVideoActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:taskAffinity=""
            android:theme="@style/Theme.MyApplication" />

        <!-- BroadcastReceiver that listens for PHONE_STATE broadcasts and
             launches CallVideoActivity when the phone starts ringing.
             Exported=false because the system still delivers protected
             broadcasts to non-exported receivers. -->
        <receiver
            android:name=".CallVideoReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Foreground Service that monitors incoming calls.
             This is the primary mechanism for call detection on Android 8.0+
             because manifest-registered receivers don't receive PHONE_STATE
             broadcasts for non-dialer apps. -->
        <service
            android:name=".CallMonitorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- InCallService - This is the PROPER way to intercept calls!
             User must set this app as "Default Caller ID & Spam App" in Settings.
             
             This gives us full control over incoming calls:
             - Receive onCallAdded() when call comes in
             - Use call.answer() and call.reject() directly
             - No need for foreground service or broadcast receiver
             
             The BIND_INCALL_SERVICE permission allows us to be a call handling app. -->
        <service
            android:name=".CallInCallService"
            android:permission="android.permission.BIND_INCALL_SERVICE"
            android:exported="true"
            android:foregroundServiceType="phoneCall">
            <meta-data
                android:name="android.telecom.INCALL_SERVICE_UI"
                android:value="true" />
        </service>
    </application>

</manifest>
