# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=placeholder_api_key
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder
# Google OAuth Web Client ID -- used by GoogleSignInOptions.requestIdToken().
# Get it from Google Cloud Console -> APIs & Services -> Credentials ->
#   Create Credentials -> OAuth client ID -> Web application.
# (NOT the Android one -- Supabase's Google provider is configured with the
#  Web client ID, so the Android app needs to request a token for THAT
#  audience so Supabase can verify it.)
GOOGLE_WEB_CLIENT_ID=PLACEHOLDER_REPLACE_ME
